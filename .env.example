# Copy this file to .env and replace the value with one generated by:
# python generate_fernet_key.py
PYDOG_FERNET_KEY=

# Optional runtime settings. Values in the shell override pydog.example.ini.
PYDOG_CONFIG_FILE=
PYDOG_DB_PATH=data/webMonitor.db
PYDOG_MONITOR_MIN_SLEEP_SECONDS=180
PYDOG_MONITOR_MAX_SLEEP_SECONDS=300
PYDOG_REQUEST_TIMEOUT_SECONDS=10
PYDOG_LOG_LEVEL=INFO
PYDOG_LOG_FORMAT=text
